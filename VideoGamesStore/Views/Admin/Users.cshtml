@model IEnumerable<VideoGamesStore.ViewModels.Admin.UserManagementViewModel>
@{ ViewData["Title"] = "Управление пользователями"; }
<h2 class="mb-3">Управление пользователями</h2>
<form method="get" class="row g-2 mb-3"><div class="col-md-5"><input class="form-control" name="search" value="@ViewBag.Search" placeholder="Поиск по логину/email" /></div><div class="col-md-2"><button class="btn btn-outline-light w-100">Найти</button></div></form>
<div class="table-responsive"><table class="table table-dark table-hover align-middle"><thead><tr><th>Пользователь</th><th>Email</th><th>Роль</th><th>Статус</th><th></th></tr></thead><tbody>
@foreach (var user in Model) {
<tr><td>@user.Username</td><td>@user.Email</td><td>@user.Role</td><td>@(user.IsActive ? "Активен" : "Заблокирован")</td><td class="d-flex gap-2 flex-wrap">
<form asp-action="ToggleRole" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@user.Id"/><button class="btn btn-sm btn-warning">Сменить роль</button></form>
<form asp-action="ToggleBan" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@user.Id"/><button class="btn btn-sm btn-secondary">@(user.IsActive ? "Бан" : "Разбан")</button></form>
<form asp-action="DeleteUser" method="post" onsubmit="return confirm('Удалить пользователя?');">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@user.Id"/><button class="btn btn-sm btn-danger">Удалить</button></form>
</td></tr>
}
</tbody></table></div>
