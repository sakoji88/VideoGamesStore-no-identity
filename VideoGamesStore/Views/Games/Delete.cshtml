@model VideoGamesStore.Models.Game

@{
    ViewData["Title"] = "Удаление игры";
}

<h2 class="mb-4 text-danger">Удаление игры</h2>

<div class="alert alert-warning">
    Вы действительно хотите удалить эту игру?
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h4>@Model.Title</h4>
        <p><strong>Жанр:</strong> @Model.Genre?.Name</p>
        <p><strong>Издатель:</strong> @(Model.Publisher?.Name ?? "Не указан")</p>
        <p><strong>Цена:</strong> @Model.Price.ToString("0.00") ₽</p>
        <p><strong>Остаток:</strong> @Model.Stock</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>