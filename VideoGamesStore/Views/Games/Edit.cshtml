@model VideoGamesStore.Models.Game

@{
    ViewData["Title"] = "Редактировать игру";
}

<h2 class="mb-4">Редактировать игру</h2>

<form asp-action="Edit" method="post" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />

    <div class="mb-3">
        <label class="form-label">Название</label>
        <input name="Title" value="@Model.Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Описание</label>
        <textarea name="Description" class="form-control" rows="4">@Model.Description</textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Цена</label>
        <input name="Price" value="@Model.Price.ToString().Replace('.', ',')" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Остаток</label>
        <input name="Stock" value="@Model.Stock" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Жанр</label>
        <select name="GenreId" asp-items="ViewBag.Genres" class="form-select"></select>
    </div>

    <div class="mb-3">
        <label class="form-label">Издатель</label>
        <select name="PublisherId" asp-items="ViewBag.Publishers" class="form-select">
            <option value="">Не указан</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Платформы</label>
        <select name="selectedPlatforms" asp-items="ViewBag.Platforms" multiple class="form-select"></select>
    </div>

    <div class="mb-3">
        <label class="form-label">Путь к изображению</label>
        <input name="CoverImageUrl" value="@Model.CoverImageUrl" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Дата релиза</label>
        <input name="ReleaseDate" value="@(Model.ReleaseDate.HasValue? Model.ReleaseDate.Value.ToString("yyyy-MM-dd") : "")" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Рейтинг</label>
        <input name="Rating" value="@(Model.Rating.HasValue? Model.Rating.Value.ToString().Replace('.', ',') : "")" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Возрастной рейтинг</label>
        <input name="AgeRating" value="@Model.AgeRating" class="form-control" />
    </div>

    <div class="form-check mb-3">
        <input type="checkbox" name="IsActive" value="true" class="form-check-input" @(Model.IsActive ? "checked" : "") />
        <input type="hidden" name="IsActive" value="false" />
        <label class="form-check-label">Активна</label>
    </div>

    <button type="submit" class="btn btn-primary">Сохранить</button>
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</form>