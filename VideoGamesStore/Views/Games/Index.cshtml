@model VideoGamesStore.ViewModels.Games.GamesIndexViewModel
@{ ViewData["Title"] = "Каталог игр"; }

<section class="hero mb-4">
    <h1>Каталог игр</h1>
    <p>Выбирайте хиты для PC и консолей.</p>
</section>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-4"><input type="text" name="searchString" value="@Model.SearchString" class="form-control" placeholder="Поиск по названию" /></div>
    <div class="col-md-3"><select name="genreId" asp-items="Model.Genres" class="form-select"><option value="">Все жанры</option></select></div>
    <div class="col-md-3"><select name="platformId" asp-items="Model.Platforms" class="form-select"><option value="">Все платформы</option></select></div>
    <div class="col-md-2"><button class="btn btn-primary w-100">Фильтр</button></div>
</form>

<div class="d-flex justify-content-between mb-3">
    <div class="btn-group">
        <a asp-action="Index" asp-route-sortOrder="@(Model.SortOrder == "title_desc" ? "" : "title_desc")" asp-route-searchString="@Model.SearchString" asp-route-genreId="@Model.GenreId" asp-route-platformId="@Model.PlatformId" class="btn btn-outline-light">Название</a>
        <a asp-action="Index" asp-route-sortOrder="@(Model.SortOrder == "price_asc" ? "price_desc" : "price_asc")" asp-route-searchString="@Model.SearchString" asp-route-genreId="@Model.GenreId" asp-route-platformId="@Model.PlatformId" class="btn btn-outline-light">Цена</a>
    </div>
    @if (User.IsInRole("Admin")) { <a asp-action="Create" class="btn btn-success">Добавить игру</a> }
</div>

<div class="row g-4">
@foreach (var game in Model.Items)
{
    <div class="col-md-6 col-lg-4">
        <div class="card game-card h-100">
            <img src="@(string.IsNullOrWhiteSpace(game.CoverImageUrl) ? "/images/games/witcher3.jpg" : game.CoverImageUrl)" class="card-img-top" alt="@game.Title" />
            <div class="card-body d-flex flex-column">
                <h5>@game.Title</h5>
                <p class="text-secondary small mb-1">@game.Genre?.Name · @(game.Publisher?.Name ?? "Unknown")</p>
                <p class="small mb-2">@string.Join(", ", game.Platforms.Select(p => p.Name))</p>
                <p class="fw-bold mt-auto">@game.Price.ToString("0.00") ₽</p>
                <a asp-action="Details" asp-route-id="@game.Id" class="btn btn-primary mb-2">Подробнее</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-controller="Cart" asp-action="Add" method="post">@Html.AntiForgeryToken()<input type="hidden" name="gameId" value="@game.Id" /><button class="btn btn-outline-success w-100">В корзину</button></form>
                }
                @if (User.IsInRole("Admin"))
                {
                    <div class="d-flex gap-2 mt-2"><a asp-action="Edit" asp-route-id="@game.Id" class="btn btn-sm btn-warning w-100">Ред.</a><a asp-action="Delete" asp-route-id="@game.Id" class="btn btn-sm btn-danger w-100">Удалить</a></div>
                }
            </div>
        </div>
    </div>
}
</div>

@if (Model.TotalPages > 1)
{
<nav class="mt-4"><ul class="pagination justify-content-center">
@for (var i = 1; i <= Model.TotalPages; i++)
{
<li class="page-item @(Model.Page == i ? "active" : "")"><a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchString="@Model.SearchString" asp-route-genreId="@Model.GenreId" asp-route-platformId="@Model.PlatformId" asp-route-sortOrder="@Model.SortOrder">@i</a></li>
}
</ul></nav>
}
